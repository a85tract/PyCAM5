module buffer

  !----------------------------------------------------------------------- 
  ! 
  ! Purpose: 
  !   LOW level handler for f90 arrays. 
  !
  ! Author: J. Edwards
  !
  ! This file is used with genf90.pl to generate buffer.F90  
  ! 
  !-----------------------------------------------------------------------

  use shr_kind_mod,     only: r8 => shr_kind_r8, r4=> shr_kind_r4, i4=> shr_kind_i4
  use cam_logfile,      only: iulog
  use cam_abortutils,   only: endrun
  use iso_c_binding,    only: c_int64_t

  implicit none
  private
  ! The maximum number of dims in a fortran array
#define MAXDIMS 7  


  type buffer_field_default_type
     private
     real(r8), pointer :: data(:,:,:,:,:,:,:) => null()
  end type buffer_field_default_type

  ! TYPE int,double,real 
  type buffer_field_{TYPE}
     private
     {VTYPE}, pointer :: data(:,:,:,:,:,:,:) => null()
  end type buffer_field_{TYPE}

  integer(i4), parameter,public :: dtype_i4=1
  real(r8), parameter,public :: dtype_r8=1_r8
  real(r4), parameter,public :: dtype_r4=1_r4

  interface buffer_field_deallocate
     ! TYPE int,double,real 
     module procedure  buffer_field_deallocate_{TYPE}
  end interface

  interface buffer_field_allocate
     ! TYPE int,double,real 
     module procedure  buffer_field_allocate_{TYPE}
  end interface

  interface buffer_set_field
     ! TYPE int,double,real 
     module procedure  buffer_set_field_const_{TYPE}
     ! DIMS 1,2,3,4,5,6,7
     ! TYPE int,double,real 
     module procedure buffer_set_field_{DIMS}d_{TYPE}
  end interface

  interface buffer_get_field_ptr
     ! DIMS 1,2,3,4,5,6,7
     ! TYPE int,double,real 
     module procedure buffer_get_field_ptr_{DIMS}d_{TYPE}
  end interface

  public :: buffer_field_deallocate, buffer_field_allocate, buffer_set_field, buffer_get_field_ptr, buffer_field_default_type
  public :: buffer_field_is_alloc

  interface
     function buffer_field_deallocate_codon(tag) result(tag_out) bind(c, name='buffer_field_deallocate_codon')
       import :: c_int64_t
       integer(c_int64_t), value :: tag
       integer(c_int64_t) :: tag_out
     end function buffer_field_deallocate_codon
     function buffer_field_allocate_codon(tag) result(tag_out) bind(c, name='buffer_field_allocate_codon')
       import :: c_int64_t
       integer(c_int64_t), value :: tag
       integer(c_int64_t) :: tag_out
     end function buffer_field_allocate_codon
     function buffer_field_is_alloc_codon(tag) result(tag_out) bind(c, name='buffer_field_is_alloc_codon')
       import :: c_int64_t
       integer(c_int64_t), value :: tag
       integer(c_int64_t) :: tag_out
     end function buffer_field_is_alloc_codon
     function buffer_get_field_ptr_codon(tag) result(tag_out) bind(c, name='buffer_get_field_ptr_codon')
       import :: c_int64_t
       integer(c_int64_t), value :: tag
       integer(c_int64_t) :: tag_out
     end function buffer_get_field_ptr_codon
     function buffer_set_field_codon(tag) result(tag_out) bind(c, name='buffer_set_field_codon')
       import :: c_int64_t
       integer(c_int64_t), value :: tag
       integer(c_int64_t) :: tag_out
     end function buffer_set_field_codon
     function buffer_set_field_const_codon(tag) result(tag_out) bind(c, name='buffer_set_field_const_codon')
       import :: c_int64_t
       integer(c_int64_t), value :: tag
       integer(c_int64_t) :: tag_out
     end function buffer_set_field_const_codon
  end interface

  
CONTAINS

  logical function buffer_use_native(selector)
    character(len=*), intent(in) :: selector
    character(len=32) :: impl_name
    integer :: status, n, i, code

    impl_name = 'codon'
    call cam_codon_get_impl(selector, impl_name, n, status)
    if (status == 0 .and. n > 0) then
       do i = 1, n
          code = iachar(impl_name(i:i))
          if (code >= iachar('A') .and. code <= iachar('Z')) then
             impl_name(i:i) = achar(code + iachar('a') - iachar('A'))
          end if
       end do
       buffer_use_native = trim(adjustl(impl_name(:n))) == 'native'
    else
       buffer_use_native = .false.
    end if
  end function buffer_use_native

! TYPE int,double,real
  subroutine buffer_field_deallocate_{TYPE}(bfg, dtype)

    type(buffer_field_default_type),intent(inout) :: bfg
    {VTYPE}, intent(in) :: dtype

    type(buffer_field_{TYPE}) :: b1
    integer(c_int64_t) :: tag_out
    logical, save :: buffer_field_deallocate_logged = .false.

    if (.not. buffer_use_native('BUFFER_FIELD_DEALLOCATE_IMPL')) then
       tag_out = buffer_field_deallocate_codon(87_c_int64_t)
       if (tag_out /= 87_c_int64_t) then
          write(iulog,*) 'buffer_field_deallocate_codon tag roundtrip failed'
          stop 2
       end if
       if (.not. buffer_field_deallocate_logged) then
          write(iulog,*) 'buffer_field_deallocate_ implementation = codon'
          buffer_field_deallocate_logged = .true.
       end if
    end if

    b1 = transfer(bfg, b1)

    if(.not.associated(b1%data)) then
       call endrun('Attempt to deallocate unassociated array ptr')
    end if

    deallocate(b1%data)

    nullify(bfg%data)

  end subroutine buffer_field_deallocate_{TYPE}

  logical function buffer_field_is_alloc(bfg)
    type(buffer_field_default_type),intent(in) :: bfg
    integer(c_int64_t) :: tag_out
    logical, save :: buffer_field_is_alloc_logged = .false.

    if (.not. buffer_use_native('BUFFER_FIELD_IS_ALLOC_IMPL')) then
       tag_out = buffer_field_is_alloc_codon(94_c_int64_t)
       if (tag_out /= 94_c_int64_t) then
          write(iulog,*) 'buffer_field_is_alloc_codon tag roundtrip failed'
          stop 2
       end if
       if (.not. buffer_field_is_alloc_logged) then
          write(iulog,*) 'buffer_field_is_alloc implementation = codon'
          buffer_field_is_alloc_logged = .true.
       end if
    end if

    buffer_field_is_alloc = associated(bfg%data) 

  end function buffer_field_is_alloc


! TYPE int,double,real
  subroutine buffer_field_allocate_{TYPE} (bfg, dimsizes, dtype)

    type(buffer_field_default_type),intent(inout) :: bfg
    integer, intent(in) :: dimsizes(:)
    integer :: alldimsizes( MAXDIMS )
    {VTYPE}, intent(in) :: dtype
    integer :: ierr

    type(buffer_field_{TYPE}) :: b1
    integer(c_int64_t) :: tag_out
    logical, save :: buffer_field_allocate_logged = .false.

    if (.not. buffer_use_native('BUFFER_FIELD_ALLOCATE_IMPL')) then
       tag_out = buffer_field_allocate_codon(124_c_int64_t)
       if (tag_out /= 124_c_int64_t) then
          write(iulog,*) 'buffer_field_allocate_codon tag roundtrip failed'
          stop 2
       end if
       if (.not. buffer_field_allocate_logged) then
          write(iulog,*) 'buffer_field_allocate_ implementation = codon'
          buffer_field_allocate_logged = .true.
       end if
    end if

    alldimsizes(:) = 1
    alldimsizes(1:size(dimsizes)) = dimsizes

    if(associated(bfg%data)) then
       call endrun('Attempt to allocate array to associated ptr')
    end if

    allocate(b1%data(alldimsizes(1),alldimsizes(2),alldimsizes(3),alldimsizes(4),&
         alldimsizes(5),alldimsizes(6),alldimsizes(7)),stat=ierr)

    if(ierr/=0) then
       call endrun("allocate failed")
    end if

    bfg = transfer(b1,bfg)

  end subroutine buffer_field_allocate_{TYPE}

  ! TYPE int,double,real 
  subroutine buffer_set_field_const_{TYPE}(bfg, const, start,kount)
    type(buffer_field_default_type) :: bfg
    {VTYPE}, intent(in) :: const
    integer, intent(in), optional :: start(:),kount(:)

    type(buffer_field_{TYPE}) :: ptr

    integer :: i, ns, strt(7), fin(7), cnt(7)
    integer(c_int64_t) :: tag_out
    logical, save :: buffer_set_field_const_logged = .false.

    if (.not. buffer_use_native('BUFFER_SET_FIELD_CONST_IMPL')) then
       tag_out = buffer_set_field_const_codon(161_c_int64_t)
       if (tag_out /= 161_c_int64_t) then
          write(iulog,*) 'buffer_set_field_const_codon tag roundtrip failed'
          stop 2
       end if
       if (.not. buffer_set_field_const_logged) then
          write(iulog,*) 'buffer_set_field_const_ implementation = codon'
          buffer_set_field_const_logged = .true.
       end if
    end if

    ptr = transfer(bfg, ptr)        

    if(present(start).and.present(kount)) then
       strt(:) = 1
       cnt = shape(ptr%data)

       ns = size(start)
       strt(1:ns) = start
    
       fin = strt+cnt-1

       do i=1,ns
         fin(i) = strt(i)+kount(i)-1
         if(strt(i)<1 .or. fin(i)>cnt(i)) then
           call endrun('Start plus kount exceeds dimension bounds')
         endif
       enddo


       ptr%data(strt(1):fin(1),strt(2):fin(2),strt(3):fin(3),strt(4):fin(4),&
            strt(5):fin(5),strt(6):fin(6),strt(7):fin(7))=const
    else
       ptr%data = const
    endif

  end subroutine buffer_set_field_const_{TYPE}

  !=========================================================================================
  ! 
  ! Given a physics_buffer chunk and an index return a pointer to a field chunk 
  ! 
  !

  ! TYPE int,double,real 
  ! DIMS 1,2,3,4,5,6,7
  subroutine buffer_get_field_ptr_{DIMS}d_{TYPE}(bfg, field, start,kount)
    type(buffer_field_default_type), intent(in) :: bfg
    {VTYPE}, pointer :: field{DIMSTR}
    integer, intent(in), optional :: start(:), kount(:)
    type(buffer_field_{TYPE}), target :: ptr
    
    integer :: ns, strt(7), fin(7), cnt(7)
    integer(c_int64_t) :: tag_out
    logical, save :: buffer_get_field_ptr_logged = .false.

    if (.not. buffer_use_native('BUFFER_GET_FIELD_PTR_IMPL')) then
       tag_out = buffer_get_field_ptr_codon(212_c_int64_t)
       if (tag_out /= 212_c_int64_t) then
          write(iulog,*) 'buffer_get_field_ptr_codon tag roundtrip failed'
          stop 2
       end if
       if (.not. buffer_get_field_ptr_logged) then
          write(iulog,*) 'buffer_get_field_ptr_ implementation = codon'
          buffer_get_field_ptr_logged = .true.
       end if
    end if

    ptr = transfer(bfg, ptr)        


    strt(:) = 1
    cnt = shape(ptr%data)

    if(present(start)) then
       ns = size(start)
       strt(1:ns) = start
    end if
    if(present(kount)) then
       cnt(1:ns) = kount
    end if
    fin = strt+cnt-1

#if  ({DIMS}==1)
    field => ptr%data(strt(1):fin(1),strt(2),strt(3),strt(4),strt(5),strt(6),strt(7))
#elif ({DIMS}==2)
    field => ptr%data(strt(1):fin(1),strt(2):fin(2),strt(3),strt(4),strt(5),strt(6),strt(7))
#elif ({DIMS}==3)
    field => ptr%data(strt(1):fin(1),strt(2):fin(2),strt(3):fin(3),strt(4),strt(5),strt(6),strt(7))
#elif ({DIMS}==4)
    field => ptr%data(strt(1):fin(1),strt(2):fin(2),strt(3):fin(3),strt(4):fin(4),strt(5),strt(6),strt(7))
#elif ({DIMS}==5)
    field => ptr%data(strt(1):fin(1),strt(2):fin(2),strt(3):fin(3),strt(4):fin(4),strt(5):fin(5),strt(6),strt(7))
#elif ({DIMS}==6)
    field => ptr%data(strt(1):fin(1),strt(2):fin(2),strt(3):fin(3),strt(4):fin(4),&
         strt(5):fin(5),strt(6):fin(6),strt(7))
#else
    field => ptr%data(strt(1):fin(1),strt(2):fin(2),strt(3):fin(3),strt(4):fin(4),&
         strt(5):fin(5),strt(6):fin(6),strt(7):fin(7))
#endif

  end subroutine buffer_get_field_ptr_{DIMS}d_{TYPE}

  ! TYPE int,double,real 
  ! DIMS 1,2,3,4,5,6,7
  subroutine buffer_set_field_{DIMS}d_{TYPE}(bfg,field,start,kount)
    type(buffer_field_default_type) :: bfg
    {VTYPE},intent(in) :: field{DIMSTR}
    integer,intent(in),optional :: start(:),kount(:)
    type(buffer_field_{TYPE}) :: ptr

    integer :: i, nc, strt(7), fin(7), cnt(7)
    integer(c_int64_t) :: tag_out
    logical, save :: buffer_set_field_logged = .false.

    if (.not. buffer_use_native('BUFFER_SET_FIELD_IMPL')) then
       tag_out = buffer_set_field_codon(275_c_int64_t)
       if (tag_out /= 275_c_int64_t) then
          write(iulog,*) 'buffer_set_field_codon tag roundtrip failed'
          stop 2
       end if
       if (.not. buffer_set_field_logged) then
          write(iulog,*) 'buffer_set_field_ implementation = codon'
          buffer_set_field_logged = .true.
       end if
    end if

    ptr = transfer(bfg,ptr)
    if(present(start).and.present(kount)) then
       strt(:) = 1
       cnt = shape(ptr%data)

       nc=size(start)
       strt(1:nc) = start
       fin = strt+cnt-1

       do i=1,nc
         fin(i) = strt(i)+kount(i)-1
         if(strt(i)<1 .or. fin(i)>cnt(i)) then
           call endrun('Start plus kount exceeds dimension bounds')
         endif
       enddo


#if  ({DIMS}==1)
       ptr%data(strt(1):fin(1),strt(2),strt(3),strt(4),strt(5),strt(6),strt(7))=field
#elif ({DIMS}==2)
       ptr%data(strt(1):fin(1),strt(2):fin(2),strt(3),strt(4),strt(5),strt(6),strt(7))=field
#elif ({DIMS}==3)
       ptr%data(strt(1):fin(1),strt(2):fin(2),strt(3):fin(3),strt(4),strt(5),strt(6),strt(7))=field
#elif ({DIMS}==4)
       ptr%data(strt(1):fin(1),strt(2):fin(2),strt(3):fin(3),strt(4):fin(4),strt(5),strt(6),strt(7))=field
#elif ({DIMS}==5)
       ptr%data(strt(1):fin(1),strt(2):fin(2),strt(3):fin(3),strt(4):fin(4),strt(5):fin(5),strt(6),strt(7))=field
#elif ({DIMS}==6)
       ptr%data(strt(1):fin(1),strt(2):fin(2),strt(3):fin(3),strt(4):fin(4),&
            strt(5):fin(5),strt(6):fin(6),strt(7))=field
#else
       ptr%data(strt(1):fin(1),strt(2):fin(2),strt(3):fin(3),strt(4):fin(4),&
            strt(5):fin(5),strt(6):fin(6),strt(7):fin(7))=field
#endif
    else
#if ({DIMS}==1)
       ptr%data(:,1,1,1,1,1,1) = field
#elif({DIMS}==2)
       ptr%data(:,:,1,1,1,1,1) = field
#elif({DIMS}==3)
       ptr%data(:,:,:,1,1,1,1) = field
#elif({DIMS}==4)
       ptr%data(:,:,:,:,1,1,1) = field
#elif({DIMS}==5)
       ptr%data(:,:,:,:,:,1,1) = field
#elif({DIMS}==6)
       ptr%data(:,:,:,:,:,:,1) = field
#else
       ptr%data = field
#endif
    end if
  end subroutine buffer_set_field_{DIMS}d_{TYPE}



end module buffer




